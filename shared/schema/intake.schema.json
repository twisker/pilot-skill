{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://pilot.local/schema/intake",
  "title": "Intake",
  "description": "用户出行需求画像（v4.0 冻结契约）。写入 ~/.pilot/workspace/<trip>/intake.json。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "trip_id",
    "destination",
    "dates",
    "party",
    "transport",
    "preferences",
    "origin_city",
    "locale"
  ],
  "properties": {
    "trip_id": {
      "type": "string",
      "minLength": 1
    },
    "destination": {
      "type": "string",
      "minLength": 1
    },
    "dates": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start", "end"],
      "properties": {
        "start": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "end": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        }
      }
    },
    "party": {
      "type": "object",
      "additionalProperties": false,
      "required": ["adults", "children", "seniors"],
      "properties": {
        "adults": { "type": "integer", "minimum": 0 },
        "children": { "type": "integer", "minimum": 0 },
        "seniors": { "type": "integer", "minimum": 0 }
      }
    },
    "budget_cny": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "transport": {
      "type": "string",
      "enum": ["self-drive", "public", "mixed"]
    },
    "preferences": {
      "type": "array",
      "items": { "type": "string" }
    },
    "origin_city": {
      "type": "string",
      "minLength": 1
    },
    "locale": {
      "type": "string",
      "enum": ["zh", "en"]
    }
  }
}
