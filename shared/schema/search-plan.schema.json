{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://pilot.local/schema/search-plan",
  "title": "SearchPlan",
  "description": "搜索编排计划与每源执行状态（v4.0 冻结契约，spec §4）。写入 ~/.pilot/workspace/<trip>/search-plan.json。",
  "type": "object",
  "additionalProperties": false,
  "required": ["trip_id", "query_intent", "sources"],
  "properties": {
    "trip_id": { "type": "string", "minLength": 1 },
    "query_intent": { "type": "string" },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "category", "method", "queries", "status", "result_count"],
        "properties": {
          "name": { "type": "string" },
          "category": {
            "type": "string",
            "enum": ["travelogue", "community", "video", "photo"]
          },
          "method": {
            "type": "string",
            "enum": ["websearch", "webfetch", "scrape"]
          },
          "queries": {
            "type": "array",
            "items": { "type": "string" }
          },
          "status": {
            "type": "string",
            "enum": ["pending", "done", "partial", "failed"]
          },
          "result_count": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "coverage_note": {
      "type": ["string", "null"]
    }
  }
}
