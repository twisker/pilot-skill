{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://pilot.local/schema/travelogue",
  "title": "Travelogue",
  "description": "实时搜索抓取后结构化整理的游记（v4.0 冻结契约，spec §5.1）。写入 ~/.pilot/workspace/<trip>/travelogues/<id>.json。",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "meta", "summary", "route", "quality"],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "author", "source", "fetch_quality"],
      "properties": {
        "title": { "type": "string" },
        "author": { "type": "string" },
        "source": {
          "type": "object",
          "additionalProperties": false,
          "required": ["url", "platform", "media_type"],
          "properties": {
            "url": { "type": "string", "format": "uri" },
            "platform": { "type": "string" },
            "media_type": {
              "type": "string",
              "enum": ["text", "video", "image-set"]
            }
          }
        },
        "published_at": {
          "type": ["string", "null"],
          "format": "date"
        },
        "fetch_quality": {
          "type": "string",
          "enum": ["full", "partial", "summary-only"]
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["brief", "tags"],
      "properties": {
        "brief": {
          "type": "string",
          "maxLength": 200,
          "description": "≤200 字简介"
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "route": {
      "type": "object",
      "additionalProperties": false,
      "required": ["days"],
      "properties": {
        "days": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["day", "pois", "transport"],
            "properties": {
              "day": { "type": "integer", "minimum": 1 },
              "pois": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["name", "kind", "note"],
                  "properties": {
                    "name": { "type": "string" },
                    "kind": {
                      "type": "string",
                      "enum": ["sight", "meal", "hotel", "transit"]
                    },
                    "note": { "type": "string" }
                  }
                }
              },
              "transport": { "type": "string" },
              "stay": { "type": ["string", "null"] }
            }
          }
        }
      }
    },
    "quality": {
      "type": "object",
      "additionalProperties": false,
      "required": ["deterministic"],
      "properties": {
        "deterministic": {
          "type": "object",
          "additionalProperties": false,
          "required": ["completeness", "granularity", "media_richness", "freshness"],
          "properties": {
            "completeness": { "type": "number", "minimum": 0, "maximum": 1 },
            "granularity": { "type": "number", "minimum": 0, "maximum": 1 },
            "media_richness": { "type": "number", "minimum": 0, "maximum": 1 },
            "freshness": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        },
        "taste_score": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 10
        },
        "total": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 10
        }
      }
    }
  }
}
