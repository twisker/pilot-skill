# PILOT v4.0 环境变量模板
# 复制为 .env 并填写实际值；.env 已在 .gitignore 中，严禁入库。
# 说明：以下均为 V1 使用的条目。

# ========== V1 必需 ==========

# 天地图开发者 key（地图视图底图；https://console.tianditu.gov.cn/ 申请，浏览器端类型）
TIANDITU_KEY=

# ========== V1 可选 ==========

# PILOT 数据主目录（默认 ~/.pilot，一般无需修改）
# PILOT_HOME=

# localhost UI 端口（默认 4870）
# PILOT_PORT=

# 高德地图 Web 服务 key（可选的 geocoding 兜底与 GCJ-02 纠偏；https://console.amap.com/）
# AMAP_KEY=

# ========== 站点 cookie（不走 .env）==========
# 小红书 / B站 等登录态使用 playwright storageState 文件，不放环境变量：
#   ~/.pilot/cookies/xhs.json
#   ~/.pilot/cookies/bilibili.json
# 导出方法见 docs/guide-cookies.md（`npx tsx ~/.pilot/app/tools/cookies.ts setup` 引导式导出）。
